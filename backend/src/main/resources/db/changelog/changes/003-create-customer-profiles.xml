<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet author="db" id="003-create-customer-profiles">
        <createTable tableName="customer_profiles">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="UUID">
                <constraints nullable="false" unique="true" foreignKeyName="fk_profile_user" referencedTableName="users" referencedColumnNames="id" deleteCascade="true"/>
            </column>
            <column name="phone_number" type="VARCHAR(20)"/>
            <column name="address" type="VARCHAR(255)"/>
            <column name="driver_license_number" type="VARCHAR(50)"/>
        </createTable>
    </changeSet>
</databaseChangeLog>